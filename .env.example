# CareGap Map — environment configuration (copy to .env; never commit .env)

# Root directory containing raw/ and processed/ data (default: data)
#CAREGAP_DATA_DIR=data

# JSON file overriding scoring keywords/weights/thresholds (default: built-ins).
# May contain any subset of the ScoringConfig fields, e.g.
#   {"thresholds": {"high_evidence": 60}}
#CAREGAP_SCORING_CONFIG=config/scoring_overrides.json

# Data source: "local" (CSV/Parquet under CAREGAP_DATA_DIR, default) or
# "databricks" (Unity Catalog tables via SQL warehouse)
#CAREGAP_DATA_SOURCE=local

# --- Optional LLM evidence extractor (pip install -e ".[llm]") ---
# Used only by scripts/run_llm_extraction.py; scoring stays deterministic.
#OPENAI_API_KEY=

# --- Databricks source / deployment (pip install -e ".[databricks]") ---
# See DEPLOYMENT.md. Never commit real values.
#DATABRICKS_HOST=https://<workspace>.cloud.databricks.com
#DATABRICKS_HTTP_PATH=/sql/1.0/warehouses/<warehouse-id>
#DATABRICKS_TOKEN=
#CAREGAP_DATABRICKS_CATALOG=main
#CAREGAP_DATABRICKS_SCHEMA=caregap
