{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "caregap_codex_icu_batch",
  "description": "Schema version 1 - batch ICU evidence extraction result for CareGap Map.",
  "type": "object",
  "additionalProperties": false,
  "required": ["records"],
  "properties": {
    "records": {
      "type": "array",
      "minItems": 1,
      "maxItems": 100,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "unique_id",
          "explicit_icu_claim",
          "icu_bed_count",
          "icu_subtypes",
          "fragments",
          "unclear_claims",
          "explanation"
        ],
        "properties": {
          "unique_id": { "type": "string", "maxLength": 128 },
          "explicit_icu_claim": { "type": "boolean" },
          "icu_bed_count": { "type": ["integer", "null"], "minimum": 0, "maximum": 5000 },
          "icu_subtypes": {
            "type": "array",
            "maxItems": 6,
            "items": {
              "type": "string",
              "enum": [
                "general_or_unspecified",
                "cardiac_icu",
                "neonatal_icu",
                "pediatric_icu",
                "medical_icu",
                "surgical_icu"
              ]
            }
          },
          "fragments": {
            "type": "array",
            "maxItems": 20,
            "items": {
              "type": "object",
              "additionalProperties": false,
              "required": ["field", "group", "quote"],
              "properties": {
                "field": {
                  "type": "string",
                  "enum": ["description", "capability", "specialties", "procedure", "equipment"]
                },
                "group": {
                  "type": "string",
                  "enum": ["explicit_icu", "equipment", "procedure", "staffing", "negation"]
                },
                "quote": { "type": "string", "minLength": 1, "maxLength": 400 }
              }
            }
          },
          "unclear_claims": {
            "type": "array",
            "maxItems": 10,
            "items": { "type": "string", "maxLength": 300 }
          },
          "explanation": { "type": "string", "maxLength": 500 }
        }
      }
    }
  }
}
